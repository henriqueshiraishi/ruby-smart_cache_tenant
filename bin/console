#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"
require "logger"
require "rails"
require "active_record"
require "active_support/all"
require "smart_cache_tenant"

# You can add fixtures and/or initialization code here to make experimenting
# with your gem easier. You can also use a different console, if you like.

ENV["RAILS_ENV"] ||= "development"

unless defined?(Rails.application) && Rails.application
  class SmartCacheTenantConsoleApp < Rails::Application
    config.root = Dir.pwd
    config.eager_load = false
    config.logger = Logger.new($stdout)
    config.secret_key_base = "smart-cache-tenant-console"
    config.cache_store = :memory_store
    config.active_support.deprecation = :stderr
  end

  Rails.application.initialize!
end

if !ActiveRecord::Base.connected?
  ActiveRecord::Base.establish_connection(adapter: "sqlite3", database: ":memory:")

  ActiveRecord::Schema.define do
    suppress_messages do
      create_table :projects, force: true do |t|
        t.integer :tenant_id
        t.string :name
        t.timestamps null: false
      end
    end
  end

  class Project < ActiveRecord::Base
    self.table_name = "projects"

    include SmartCacheTenant::ModelCallbacks
    has_smart_cache
  end
end

SmartCacheTenant.configure do |config|
  config.enabled = true
  config.ttl = 1.hour
  config.tenant_column = :tenant_id
  config.log_queries = true
end

puts "SmartCacheTenant console loaded"
puts "Example: Project.create!(tenant_id: 1, name: 'A')"
puts "Example: Project.where(tenant_id: 1).load"
puts Project.inspect

def reload!
  Dir['lib/smart_cache_tenant/**/*.rb'].each { |file| load file }
end

require "irb"
IRB.start(__FILE__)
